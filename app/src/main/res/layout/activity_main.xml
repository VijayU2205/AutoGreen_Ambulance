<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#f0f0f0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:padding="10dp" />

        <!-- Server Status -->
        <TextView
            android:id="@+id/serverStatusTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/checking_server"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="12dp"
            android:background="#FFECB3"
            android:layout_marginBottom="20dp" />

        <!-- Login Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:id="@+id/loginSection">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/user_registration"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="16dp" />

            <!-- Name Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/full_name"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/nameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_full_name"
                android:inputType="textCapWords"
                android:background="@drawable/edittext_border"
                android:padding="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Age Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/age"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/ageEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_age"
                android:inputType="number"
                android:background="@drawable/edittext_border"
                android:padding="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Mobile Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mobile_number"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/mobileEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_mobile"
                android:inputType="phone"
                android:autofillHints="phone"
                android:background="@drawable/edittext_border"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Send OTP Button -->
            <Button
                android:id="@+id/sendOtpButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/send_otp"
                android:textSize="16sp"
                android:background="#2196F3"
                android:textColor="#FFFFFF"
                android:padding="12dp" />

            <!-- OTP Input Section -->
            <LinearLayout
                android:id="@+id/otpSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/enter_otp"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/otpEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/enter_4_digit_otp"
                    android:inputType="number"
                    android:autofillHints="smsOTP"
                    android:background="@drawable/edittext_border"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- Login Button -->
                <Button
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/verify_login"
                    android:textSize="16sp"
                    android:background="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:padding="12dp" />

                <!-- Resend OTP Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/resendOtpButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/resend_otp"
                        android:textSize="14sp"
                        android:background="#FF9800"
                        android:textColor="#FFFFFF"
                        android:padding="8dp"
                        android:layout_marginEnd="8dp"
                        android:enabled="false" />

                    <TextView
                        android:id="@+id/timerTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="#F44336"
                        android:padding="8dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Emergency Section -->
        <LinearLayout
            android:id="@+id/emergencySection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/emergency_service"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="16dp" />

            <!-- Emergency Button -->
            <Button
                android:id="@+id/emergencyButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/emergency_call"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="#F44336"
                android:textColor="#FFFFFF"
                android:padding="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/press_emergency"
                android:textSize="14sp"
                android:textColor="#666666"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <!-- Driver Status -->
            <TextView
                android:id="@+id/driverStatusTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#2E7D32"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="#E8F5E8"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Status Display -->
        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ready"
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:background="#E0E0E0" />

    </LinearLayout>

</ScrollView>